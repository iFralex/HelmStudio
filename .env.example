# ─── Auth ────────────────────────────────────────────────────────────────────
# Password for the single admin user (min 8 characters)
ADMIN_PASSWORD=change-me-please

# Secret key for signing session cookies (min 32 random characters)
SESSION_SECRET=change-me-to-a-long-random-secret-value-here

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (default: ./data/pipeline.db)
DATABASE_PATH=./data/pipeline.db

# ─── YouTube API ─────────────────────────────────────────────────────────────
# Google Cloud API key with YouTube Data API v3 enabled (min 20 characters)
YOUTUBE_API_KEY=AIza...your-youtube-api-key-here

# ─── LLM ─────────────────────────────────────────────────────────────────────
# Base URL of the LLM API (must be a valid URL)
LLM_BASE_URL=https://api.anthropic.com

# API key for the LLM provider (use 'not-needed' for local/unauthenticated endpoints)
LLM_API_KEY=not-needed

# Model identifier for the reasoning/thinking step (e.g. slow, high-quality)
LLM_MODEL_THINK=claude-opus-4-7

# Model identifier for fast/cheap operations (e.g. classification, short responses)
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# ─── Pipeline ─────────────────────────────────────────────────────────────────
# Hour (0-23) at which the pipeline cron job triggers daily (default: 4)
PIPELINE_TRIGGER_HOUR=4

# Minute (0-59) at which the pipeline cron job triggers (default: 0)
PIPELINE_TRIGGER_MINUTE=0

# Minimum subscriber count for channel qualification (default: 80000)
PIPELINE_MIN_SUBSCRIBERS=80000

# Maximum subscriber count for channel qualification (default: 1000000)
PIPELINE_MAX_SUBSCRIBERS=1000000

# ISO 3166-1 alpha-2 country code for targeting (default: IT)
PIPELINE_TARGET_COUNTRY=IT

# ISO 639-1 language code for targeting (default: it)
PIPELINE_TARGET_LANGUAGE=it

# Number of keywords to process per pipeline run (default: 30)
PIPELINE_KEYWORDS_PER_RUN=30

# Target number of newly qualified channels per run (default: 50)
PIPELINE_TARGET_QUALIFIED_PER_RUN=50

# Days of inactivity before a channel is considered inactive (default: 60)
PIPELINE_INACTIVE_DAYS=60

# Days after qualification before a channel can be re-qualified (default: 90)
PIPELINE_REQUALIFY_AFTER_DAYS=90

# YouTube Data API v3 daily quota limit (default: 10000)
PIPELINE_YOUTUBE_QUOTA_DAILY_LIMIT=10000

# Units to keep in reserve so the pipeline stops before hitting the hard quota (default: 500)
PIPELINE_YOUTUBE_QUOTA_SAFETY_BUFFER=500

# ─── Storage ─────────────────────────────────────────────────────────────────
# Root directory for all persisted data (db, logs, raw API dumps) (default: ./data)
DATA_DIR=./data

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info
