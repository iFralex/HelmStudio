{
  "name": "creator-pipeline",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=/workspace/.playwright-browsers playwright test",
    "postinstall": "node scripts/postinstall.cjs || true",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:init": "tsx scripts/init-db.ts",
    "db:reset": "tsx scripts/reset-db.ts && pnpm db:init",
    "seed:keywords": "tsx scripts/seed-keywords.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "worker:run": "tsx src/worker/run.ts",
    "worker:manual": "tsx src/worker/run.ts --manual",
    "worker:qualify": "tsx src/worker/run.ts --manual --qualify-only"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "openai": "^6.38.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "youtube-transcript": "1.3.1",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "happy-dom": "^20.9.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
